# Скопируйте в файл .env в папке star-oracle (значения: Supabase → Project Settings → API)
# Подойдут имена с SUPABASE_ или с VITE_ (оба варианта читает Vite).

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# Альтернатива:
# VITE_SUPABASE_URL=...
# VITE_SUPABASE_ANON_KEY=...
