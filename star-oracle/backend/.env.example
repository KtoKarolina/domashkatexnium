# Supabase — URL проекта
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Публичный ключ (anon) — безопасен для фронтенда
SUPABASE_ANON_KEY=your_anon_key

# Серверный ключ — ТОЛЬКО на бэкенде, НИКОГДА на клиенте
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Сервер
PORT=3001

# CORS: разрешённые origin фронтенда (через запятую, без пробелов вокруг или с trim).
# В production обязателен URL вашего сайта, иначе браузер заблокирует API.
# Локально при пустом значении: 127.0.0.1/localhost:5173, 4173, 3000.
# CORS_ORIGINS=https://your-frontend.railway.app,http://127.0.0.1:5173

# E2E (Playwright): скопируйте в backend/.env и подставьте свои значения (не коммитить .env).
# Без E2E_SETUP_SECRET маршрут POST /api/dev/e2e-ensure-user отключён (404). DISABLE_E2E_DEV_ENDPOINT=1 — выкл. насильно.
E2E_SETUP_SECRET=replace-with-random-string
E2E_USER_EMAIL=test@example.com
E2E_USER_PASSWORD=replace-min-8-chars
